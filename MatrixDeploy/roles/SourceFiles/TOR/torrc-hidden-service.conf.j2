# TOR hidden service configuration for tenant {{ item.id }}
# Included via: /etc/tor/torrc.d/{{ item.id }}.conf
# Managed by Ansible — do not edit manually.
#
# Architecture: TOR maps .onion ports directly to the container ports on localhost.
# No additional Nginx vhost is required — the existing containers handle the requests.
#
# matrix_onion:port 80   → localhost:{{ item.element_port }}  (Element Web client container)
# matrix_onion:port 8448 → localhost:{{ item.matrix_port }}   (Synapse homeserver container)
# admin_onion:port 80    → localhost:{{ item.admin_port }}     (Admin portal container)
#
# The .onion addresses are auto-generated by TOR from the key in the HiddenServiceDir.
# Read them from /var/lib/tor/{{ item.id }}_matrix/hostname  and
#                /var/lib/tor/{{ item.id }}_admin/hostname
# after TOR reloads.

HiddenServiceDir /var/lib/tor/{{ item.id }}_matrix/
HiddenServicePort 80 127.0.0.1:{{ item.element_port }}
HiddenServicePort 8448 127.0.0.1:{{ item.matrix_port }}

HiddenServiceDir /var/lib/tor/{{ item.id }}_admin/
HiddenServicePort 80 127.0.0.1:{{ item.admin_port }}
