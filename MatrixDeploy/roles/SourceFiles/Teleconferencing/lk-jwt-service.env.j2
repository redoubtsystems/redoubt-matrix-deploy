# lk-jwt-service environment — bridges Matrix auth to LiveKit JWTs
# Tenant: {{ item.id }}  |  Domain: {{ item.fulldomain }}
# Managed by Ansible — do not edit manually.

# LiveKit SFU WebSocket URL — this is what clients receive in their JWT
# and use to connect to the SFU. Proxied by Nginx on the tenant domain.
LIVEKIT_URL=wss://{{ item.fulldomain }}/livekit/sfu/

# API credentials — must match the keys: entry in livekit.yaml
LIVEKIT_KEY={{ livekit_api_key }}
LIVEKIT_SECRET={{ livekit_api_secret }}

# Listen address inside the container (mapped to host port {{ item.livekit_jwt_port }})
LIVEKIT_JWT_BIND=:8080
