server {
  listen 80;
  server_name admin.{{ _vhost_domain }};

  location /.well-known/acme-challenge/ {
    root /var/www/html;
  }

  location / {
{% if item.network_addon | default('') == 'wireguard' %}
    allow 10.100.{{ item.wireguard_port - 51800 }}.0/24;
    deny all;
{% endif %}
    return 301 https://$host$request_uri;
  }
}

{% if _admin_tls_cert_exists | default(false) %}
server {
  listen 443 ssl http2;
  server_name admin.{{ _vhost_domain }};

  ssl_certificate /etc/letsencrypt/live/admin.{{ _vhost_domain }}/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/admin.{{ _vhost_domain }}/privkey.pem;
  ssl_protocols TLSv1.2 TLSv1.3;

  add_header X-Content-Type-Options nosniff;
  add_header X-Frame-Options DENY;
  add_header X-XSS-Protection "1; mode=block";

{% if item.network_addon | default('') == 'wireguard' %}
  # Restrict access to WireGuard subnet only
  allow 10.100.{{ item.wireguard_port - 51800 }}.0/24;
  deny all;
{% endif %}

  location / {
    proxy_pass http://127.0.0.1:{{ item.admin_port }};
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  }
}
{% endif %}
