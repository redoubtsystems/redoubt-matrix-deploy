SYNAPSE_URL=http://synapse:8008
SERVER_NAME={{ item.fulldomain }}
FLASK_SECRET_KEY={{ flask_secret_key }}
SMTP_SERVER={{ smtp_server }}
SMTP_PORT={{ smtp_port }}
SMTP_USERNAME={{ smtp_username }}
SMTP_PASSWORD={{ smtp_password }}
SMTP_FROM={{ smtp_from_address }}
CHAT_URL=https://{{ item.fulldomain }}
ADMIN_URL=https://admin.{{ item.fulldomain }}
MAX_USERS={{ plans[item.plan_type].max_users }}
BILLING_SERVICE_URL={{ billing_callback_url }}
BILLING_SERVICE_SECRET={{ billing_callback_secret }}
BILLING_CUSTOMER_ID={{ item.id }}